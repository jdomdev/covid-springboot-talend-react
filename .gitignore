# IDE and build tool generated files
.vscode/
.idea/                 # IntelliJ IDEA project files
*.iml                  # IntelliJ module file
target/                # Maven build directory
.mvn/wrapper/maven-wrapper.jar # Maven wrapper executable

# Compiled class files
*.class

# Log files
*.log
/logs/                 # Optional: If you have a dedicated logs directory

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Virtual machine crash logs
hs_err_pid*
replay_pid*

# Database/Data files
# Ignore data directories, especially from Docker volumes.
*.csv
*.dat
*.db
/data/
/covid-dashboard/data/
postgres-data/         # Data volume from docker-compose.yml

# OS-generated files
.DS_Store              # macOS
Thumbs.db              # Windows

# Project-specific configuration (sensitive data)
# It's better to manage environment-specific properties outside Git.
application-*.properties
application.yml        # Common configuration formatapplication-local.properties
